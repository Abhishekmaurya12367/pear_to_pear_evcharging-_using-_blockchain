# Required: deployed contract addresses for your Solidity system.
# After copying this file to `.env`, fill in the real addresses.

VITE_USER_REGISTRY_ADDRESS=0xYourUserRegistryAddress
VITE_CHARGING_REQUEST_ADDRESS=0xYourChargingRequestAddress
VITE_MATCHING_CONTRACT_ADDRESS=0xYourMatchingContractAddress
VITE_ENERGY_VALIDATION_ADDRESS=0xYourEnergyValidationAddress
VITE_ESCROW_PAYMENT_ADDRESS=0xYourEscrowPaymentAddress

# Optional: used as `priceofenergyperkph` when creating a request.
VITE_DEFAULT_PRICE_PER_KILO=1
